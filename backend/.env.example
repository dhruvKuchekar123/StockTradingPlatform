# StockFlow Pro — Backend Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to source control.

# ─── Database ────────────────────────────────────────────────
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── Auth ────────────────────────────────────────────────────
# Generate a strong random secret: `node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"`
TOKEN_KEY=<your-64-char-random-secret>

# Google OAuth 2.0 Client ID (from Google Cloud Console)
GOOGLE_CLIENT_ID=<your-google-client-id>.apps.googleusercontent.com

# ─── Server ──────────────────────────────────────────────────
PORT=3002
FRONTEND_URL=http://localhost:3005

# ─── Email (Gmail SMTP) ───────────────────────────────────────
EMAIL_USER=<your-gmail-address>
# Use an App Password, NOT your Gmail login password
# Guide: https://support.google.com/accounts/answer/185833
EMAIL_PASS=<your-gmail-app-password>

# ─── Payment Gateway ─────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_<your-key>
RAZORPAY_KEY_SECRET=<your-razorpay-secret>

# ─── Price Data ──────────────────────────────────────────────
# Options: "yahoo" (default) | "alphavantage"
PRICE_PROVIDER=yahoo
ALPHA_VANTAGE_API_KEY=<your-alpha-vantage-key>
FINNHUB_API_KEY=<your-finnhub-key>

# ─── Cache ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
